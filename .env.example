# Base URL for the Watchmode API
# This is the API endpoint used to search for titles and streaming availability
BASE_URL=https://api.watchmode.com/v1

# Your Watchmode API Key
# Get your free API key at: https://api.watchmode.com/requestApiKey
# This key is used to authenticate requests to the Watchmode API
WATCHMODE_API_KEY=your_api_key_here
